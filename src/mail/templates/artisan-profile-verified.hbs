<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>{{appName}}</title>
</head>
<body style="margin:0;padding:0;background-color:#edf2ec;font-family:'Segoe UI',Arial,Helvetica,sans-serif;-webkit-font-smoothing:antialiased;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0"
  style="background-color:#edf2ec;padding:32px 16px;">
  <tr><td align="center">

    <!-- ── Container ── -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
      style="max-width:580px;width:100%;background:#ffffff;border-radius:16px;
             overflow:hidden;box-shadow:0 2px 12px rgba(28,69,50,0.10);">

      <!-- LOGO HEADER -->
      <tr>
        <td style="background-color:#1c4532;padding:22px 36px;">
          <table role="presentation" cellpadding="0" cellspacing="0">
            <tr>
              <td style="background:#ffffff;border-radius:8px;width:38px;height:38px;
                         text-align:center;vertical-align:middle;font-weight:900;
                         font-size:20px;color:#1c4532;line-height:38px;">J</td>
              <td style="padding-left:10px;vertical-align:middle;">
                <span style="color:#ffffff;font-size:21px;font-weight:700;
                             letter-spacing:-0.3px;">JinVa</span>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- HERO ICON BAND -->
      <tr>
        <td style="background-color:#1c4532;padding:4px 36px 36px;text-align:center;">
          <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;">
            <tr>
              <td style="background:#22c55e;border-radius:50%;width:72px;height:72px;
                         text-align:center;vertical-align:middle;font-size:34px;
                         line-height:72px;box-shadow:0 0 0 6px rgba(255,255,255,0.15);">
                &#9733;
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- BODY -->
      <tr>
        <td style="padding:36px 36px 28px;">
          <h1 style="margin:0 0 20px;color:#1c4532;font-size:24px;font-weight:700;line-height:1.3;">Your profile has been verified! &#127881;</h1><p style="margin:0 0 16px;color:#374151;font-size:15px;line-height:1.7;">Hi <strong style="color:#1c4532;">{{firstname}}</strong>,</p><p style="margin:0 0 16px;color:#374151;font-size:15px;line-height:1.7;">Congratulations! Your identity and professional credentials have been reviewed and verified by the <strong>{{appName}}</strong> team.</p>
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
            style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;margin:0 0 28px;">
            <tr><td style="padding:20px 24px;text-align:center;">
              <p style="margin:0 0 8px;display:inline-block;background:#1c4532;color:#ffffff;
                 font-size:13px;font-weight:700;padding:6px 18px;border-radius:20px;
                 letter-spacing:0.5px;">&#10003;&nbsp; VERIFIED ARTISAN</p>
              <p style="margin:8px 0 0;color:#166534;font-size:14px;line-height:1.6;">
                Your profile now displays a verified badge, increasing trust with customers and boosting your visibility in search results.
              </p>
            </td></tr>
          </table><p style="margin:0 0 16px;color:#374151;font-size:15px;line-height:1.7;">You can now receive more job applications, attract higher-quality clients, and unlock the full potential of your {{appName}} profile.</p>
          <table role="presentation" cellpadding="0" cellspacing="0"
            style="margin:0 auto 28px;">
            <tr>
              <td style="background:#1c4532;border-radius:9px;text-align:center;">
                <a href="{{dashboardUrl}}" style="display:inline-block;color:#ffffff;font-size:15px;
                   font-weight:600;text-decoration:none;padding:14px 36px;
                   letter-spacing:0.1px;">Go to My Dashboard</a>
              </td>
            </tr>
          </table><hr style="border:none;border-top:1px solid #e5e7eb;margin:8px 0 20px;" /><p style="margin:0;color:#9ca3af;font-size:13px;line-height:1.65;">Questions about your verified status? Contact us at <a href="mailto:{{supportEmail}}" style="color:#1c4532;">{{supportEmail}}</a>.</p>
        </td>
      </tr>


        <!-- FOOTER -->
        <tr>
          <td style="background-color:#1c4532;padding:28px 36px;text-align:center;border-radius:0 0 16px 16px;">
            <p style="margin:0 0 6px;color:#a7f3d0;font-size:13px;line-height:1.5;">
              &copy; {{year}} {{appName}}. All rights reserved.
            </p>
            <p style="margin:0;color:#6ee7b7;font-size:13px;">
              Need help?&nbsp;<a href="mailto:{{supportEmail}}" style="color:#bbf7d0;text-decoration:underline;">{{supportEmail}}</a>
            </p>
          </td>
        </tr>

    </table>
    <!-- /container -->
  </td></tr>
</table>
</body>
</html>
