<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <title>{{appName}}</title>
</head>
<body style="margin:0;padding:0;background-color:#edf2ec;font-family:'Segoe UI',Arial,Helvetica,sans-serif;-webkit-font-smoothing:antialiased;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0"
  style="background-color:#edf2ec;padding:32px 16px;">
  <tr><td align="center">

    <!-- ── Container ── -->
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
      style="max-width:580px;width:100%;background:#ffffff;border-radius:16px;
             overflow:hidden;box-shadow:0 2px 12px rgba(28,69,50,0.10);">

      <!-- LOGO HEADER -->
      <tr>
        <td style="background-color:#1c4532;padding:22px 36px;">
          <table role="presentation" cellpadding="0" cellspacing="0">
            <tr>
              <td style="background:#ffffff;border-radius:8px;width:38px;height:38px;
                         text-align:center;vertical-align:middle;font-weight:900;
                         font-size:20px;color:#1c4532;line-height:38px;">J</td>
              <td style="padding-left:10px;vertical-align:middle;">
                <span style="color:#ffffff;font-size:21px;font-weight:700;
                             letter-spacing:-0.3px;">JinVa</span>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- HERO ICON BAND -->
      <tr>
        <td style="background-color:#1c4532;padding:4px 36px 36px;text-align:center;">
          <table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;">
            <tr>
              <td style="background:#6b7280;border-radius:50%;width:72px;height:72px;
                         text-align:center;vertical-align:middle;font-size:34px;
                         line-height:72px;box-shadow:0 0 0 6px rgba(255,255,255,0.15);">
                &#10005;
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- BODY -->
      <tr>
        <td style="padding:36px 36px 28px;">
          <h1 style="margin:0 0 20px;color:#1c4532;font-size:24px;font-weight:700;line-height:1.3;">Booking not accepted</h1><p style="margin:0 0 16px;color:#374151;font-size:15px;line-height:1.7;">Hi <strong style="color:#1c4532;">{{firstname}}</strong>,</p><p style="margin:0 0 16px;color:#374151;font-size:15px;line-height:1.7;">We're sorry to inform you that the artisan was unable to accept your booking on <strong>{{appName}}</strong> at this time.</p>
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
            style="background:#f9fafb;border:1px solid #e5e7eb;border-radius:10px;margin:20px 0 28px;">
            <tr><td style="padding:18px 22px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">

              <tr>
                <td style="color:#6b7280;font-size:13px;padding:6px 0;width:42%;
                           border-bottom:1px solid #e5e7eb;vertical-align:top;">Artisan</td>
                <td style="color:#1c4532;font-size:13px;font-weight:600;padding:6px 0 6px 12px;
                           border-bottom:1px solid #e5e7eb;vertical-align:top;">{{artisanName}}</td>
              </tr>
              <tr>
                <td style="color:#6b7280;font-size:13px;padding:6px 0;width:42%;
                           border-bottom:1px solid #e5e7eb;vertical-align:top;">Scheduled Date</td>
                <td style="color:#1c4532;font-size:13px;font-weight:600;padding:6px 0 6px 12px;
                           border-bottom:1px solid #e5e7eb;vertical-align:top;">{{scheduledDate}}</td>
              </tr>
              <tr>
                <td style="color:#6b7280;font-size:13px;padding:6px 0;width:42%;
                           border-bottom:1px solid #e5e7eb;vertical-align:top;">Booking Reference</td>
                <td style="color:#1c4532;font-size:13px;font-weight:600;padding:6px 0 6px 12px;
                           border-bottom:1px solid #e5e7eb;vertical-align:top;">{{bookingId}}</td>
              </tr>
              </table>
            </td></tr>
          </table><p style="margin:0 0 16px;color:#374151;font-size:15px;line-height:1.7;">Don't worry — there are many other skilled artisans available on {{appName}}. Browse and book another artisan for your service.</p>
          <table role="presentation" cellpadding="0" cellspacing="0"
            style="margin:0 auto 28px;">
            <tr>
              <td style="background:#1c4532;border-radius:9px;text-align:center;">
                <a href="{{dashboardUrl}}" style="display:inline-block;color:#ffffff;font-size:15px;
                   font-weight:600;text-decoration:none;padding:14px 36px;
                   letter-spacing:0.1px;">Find Another Artisan</a>
              </td>
            </tr>
          </table><hr style="border:none;border-top:1px solid #e5e7eb;margin:8px 0 20px;" /><p style="margin:0;color:#9ca3af;font-size:13px;line-height:1.65;">Your satisfaction is our priority. If you need assistance finding the right artisan, please reach out to <a href="mailto:{{supportEmail}}" style="color:#1c4532;">{{supportEmail}}</a>.</p>
        </td>
      </tr>


        <!-- FOOTER -->
        <tr>
          <td style="background-color:#1c4532;padding:28px 36px;text-align:center;border-radius:0 0 16px 16px;">
            <p style="margin:0 0 6px;color:#a7f3d0;font-size:13px;line-height:1.5;">
              &copy; {{year}} {{appName}}. All rights reserved.
            </p>
            <p style="margin:0;color:#6ee7b7;font-size:13px;">
              Need help?&nbsp;<a href="mailto:{{supportEmail}}" style="color:#bbf7d0;text-decoration:underline;">{{supportEmail}}</a>
            </p>
          </td>
        </tr>

    </table>
    <!-- /container -->
  </td></tr>
</table>
</body>
</html>
